<view class="page about-page">
  <view class="topbar" style="height: {{navHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="brand">
      <button class="brand-mark icon-plane-takeoff" bindtap="goHome" aria-label="返回首页"></button>
      <text class="brand-title">关于</text>
    </view>
    <view class="icon-button">⋯</view>
  </view>

  <view class="about-hero">
    <view class="about-mark icon-plane-takeoff"></view>
    <view class="about-title">航空工具箱</view>
    <view class="about-subtitle">Aviation Toolbox</view>
    <view class="about-version">开发版本 v1.0.0</view>
