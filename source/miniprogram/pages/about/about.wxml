  <view class="about-list">
    <view class="about-item">
      <view class="about-item-label">开发者</view>
      <view class="about-item-value">Airkits Team</view>
    </view>
    <view class="about-item">
      <view class="about-item-label">联系方式</view>
      <view class="about-item-value">airkits@163.com</view>
    </view>
    <view class="about-item">
      <view class="about-item-label">数据说明</view>
